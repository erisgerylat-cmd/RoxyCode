{
  "name": "roxycode",
  "version": "0.1.0",
  "description": "RoxyCode — 洛琪希的魔法编程助手",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "roxycode": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "chalk": "^5.3.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
