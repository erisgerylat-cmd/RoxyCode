{
  "$id": "https://roxycode.dev/schemas/character.v1.json",
  "title": "RoxyCode Character Definition v1",
  "description": "JSON-only character definition schema for RoxyCode character packages.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "nameEn": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "personality": {
      "type": "string",
      "minLength": 1
    },
    "theme": {
      "type": "object",
      "properties": {
        "primary": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "secondary": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "accent": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "dim": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "error": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "success": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "tagline": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "primary",
        "secondary",
        "accent",
        "dim",
        "error",
        "success",
        "tagline"
      ],
      "additionalProperties": false
    },
    "behavior": {
      "type": "object",
      "properties": {
        "explanationStyle": {
          "type": "string",
          "enum": [
            "concise",
            "structured",
            "teaching",
            "deep",
            "playful"
          ]
        },
        "reviewFocus": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "correctness",
              "security",
              "performance",
              "maintainability",
              "testing",
              "ux",
              "learning"
            ]
          }
        },
        "riskPreference": {
          "type": "string",
          "enum": [
            "conservative",
            "balanced",
            "bold"
          ]
        },
        "preferredMode": {
          "type": "string",
          "enum": [
            "lite",
            "economic",
            "standard",
            "ultimate"
          ]
        },
        "workflowBias": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "responseRules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "explanationStyle",
        "reviewFocus",
        "riskPreference",
        "preferredMode",
        "workflowBias",
        "responseRules"
      ],
      "additionalProperties": false
    },
    "statusText": {
      "type": "object",
      "properties": {
        "thinking": {
          "type": "string"
        },
        "analyzing": {
          "type": "string"
        },
        "planning": {
          "type": "string"
        },
        "executing": {
          "type": "string"
        },
        "reading": {
          "type": "string",
          "minLength": 1
        },
        "writing": {
          "type": "string",
          "minLength": 1
        },
        "running": {
          "type": "string",
          "minLength": 1
        },
        "searching": {
          "type": "string"
        },
        "waiting": {
          "type": "string"
        },
        "done": {
          "type": "string"
        },
        "error": {
          "type": "string"
        },
        "step": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "thinking",
        "analyzing",
        "planning",
        "executing",
        "reading",
        "writing",
        "running",
        "searching",
        "waiting",
        "done",
        "error",
        "step"
      ],
      "additionalProperties": {}
    },
    "companion": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "art": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "idleLines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "thinkingLines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "successLines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warningLines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "kind",
        "art",
        "idleLines",
        "thinkingLines",
        "successLines",
        "warningLines"
      ],
      "additionalProperties": false
    },
    "splash": {
      "type": "object",
      "properties": {
        "asciiArt": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tagline": {
          "type": "string"
        },
        "welcome": {
          "type": "string"
        },
        "tips": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "tagline",
        "welcome"
      ],
      "additionalProperties": false
    },
    "easterEggs": {
      "type": "object",
      "properties": {
        "startup": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "success": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "error": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "idle": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "special": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "startup",
        "success",
        "error",
        "idle",
        "special"
      ],
      "additionalProperties": false
    },
    "errorMessages": {
      "type": "object",
      "properties": {
        "generic": {
          "type": "string"
        },
        "networkError": {
          "type": "string"
        },
        "tokenLimit": {
          "type": "string"
        },
        "toolFailed": {
          "type": "string",
          "minLength": 1
        },
        "permissionDenied": {
          "type": "string"
        },
        "rateLimit": {
          "type": "string"
        },
        "contextOverflow": {
          "type": "string"
        }
      },
      "required": [
        "generic",
        "networkError",
        "tokenLimit",
        "toolFailed",
        "permissionDenied",
        "rateLimit",
        "contextOverflow"
      ],
      "additionalProperties": {}
    },
    "systemPromptPersona": {
      "type": "string",
      "minLength": 10
    },
    "custom": {
      "type": "boolean"
    },
    "source": {
      "type": "string",
      "enum": [
        "builtin",
        "global",
        "project",
        "marketplace"
      ]
    },
    "packageInfo": {
      "type": "object",
      "properties": {
        "packageName": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "author": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "email": {
              "type": "string",
              "format": "email",
              "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
            },
            "url": {
              "type": "string",
              "format": "uri"
            }
          },
          "required": [
            "name"
          ],
          "additionalProperties": false
        },
        "license": {
          "type": "string"
        },
        "repository": {
          "type": "string",
          "format": "uri"
        },
        "installPath": {
          "type": "string",
          "minLength": 1
        },
        "installedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        }
      },
      "required": [
        "packageName",
        "version",
        "author",
        "installPath",
        "installedAt"
      ],
      "additionalProperties": false
    },
    "assets": {
      "type": "object",
      "properties": {
        "icon": {
          "type": "string",
          "minLength": 1
        },
        "avatar": {
          "type": "string",
          "minLength": 1
        },
        "splashArt": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sprites": {
          "type": "object",
          "properties": {
            "idle": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "thinking": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "success": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "warning": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "error": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false
        },
        "sounds": {
          "type": "object",
          "properties": {
            "notification": {
              "type": "string",
              "minLength": 1
            },
            "success": {
              "type": "string",
              "minLength": 1
            },
            "error": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "extensions": {
      "type": "object",
      "properties": {
        "hooks": {
          "type": "string",
          "minLength": 1
        },
        "workflows": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prompts": {
          "type": "object",
          "properties": {
            "systemPrompt": {
              "type": "string",
              "minLength": 1
            },
            "planPrompt": {
              "type": "string",
              "minLength": 1
            },
            "verificationPrompt": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "i18n": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z]{2,3}(?:-[A-Z]{2})?$"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "personality": {
                "type": "string"
              },
              "statusText": {
                "type": "object",
                "properties": {
                  "thinking": {
                    "type": "string"
                  },
                  "analyzing": {
                    "type": "string"
                  },
                  "planning": {
                    "type": "string"
                  },
                  "executing": {
                    "type": "string"
                  },
                  "reading": {
                    "type": "string",
                    "minLength": 1
                  },
                  "writing": {
                    "type": "string",
                    "minLength": 1
                  },
                  "running": {
                    "type": "string",
                    "minLength": 1
                  },
                  "searching": {
                    "type": "string"
                  },
                  "waiting": {
                    "type": "string"
                  },
                  "done": {
                    "type": "string"
                  },
                  "error": {
                    "type": "string"
                  },
                  "step": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": {}
              },
              "easterEggs": {
                "type": "object",
                "properties": {
                  "startup": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "success": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "error": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "idle": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "special": {
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                },
                "additionalProperties": false
              },
              "errorMessages": {
                "type": "object",
                "properties": {
                  "generic": {
                    "type": "string"
                  },
                  "networkError": {
                    "type": "string"
                  },
                  "tokenLimit": {
                    "type": "string"
                  },
                  "toolFailed": {
                    "type": "string",
                    "minLength": 1
                  },
                  "permissionDenied": {
                    "type": "string"
                  },
                  "rateLimit": {
                    "type": "string"
                  },
                  "contextOverflow": {
                    "type": "string"
                  }
                },
                "additionalProperties": {}
              }
            },
            "additionalProperties": {}
          },
          {
            "type": "string",
            "minLength": 1
          }
        ]
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string"
        },
        "characterType": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ageRating": {
          "type": "string",
          "enum": [
            "everyone",
            "13+",
            "16+",
            "18+"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "id",
    "name",
    "nameEn",
    "title",
    "description",
    "personality",
    "theme",
    "statusText",
    "splash",
    "easterEggs",
    "errorMessages",
    "systemPromptPersona"
  ],
  "additionalProperties": {}
}
