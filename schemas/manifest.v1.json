{
  "$id": "https://roxycode.dev/schemas/manifest.v1.json",
  "title": "RoxyCode Character Package Manifest v1",
  "description": "Manifest schema for installable RoxyCode character packages.",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 50,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "author": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "email": {
          "type": "string",
          "format": "email",
          "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "required": [
        "type",
        "url"
      ],
      "additionalProperties": false
    },
    "keywords": {
      "maxItems": 20,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "categories": {
      "maxItems": 5,
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "engines": {
      "type": "object",
      "properties": {
        "roxycode": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "roxycode"
      ],
      "additionalProperties": false
    },
    "main": {
      "default": "character.json",
      "type": "string",
      "minLength": 1
    },
    "contributes": {
      "type": "object",
      "properties": {
        "character": {
          "type": "string",
          "minLength": 1
        },
        "workflows": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "hooks": {
          "type": "string",
          "minLength": 1
        },
        "themes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string"
        },
        "characterType": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ageRating": {
          "type": "string",
          "enum": [
            "everyone",
            "13+",
            "16+",
            "18+"
          ]
        },
        "preview": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "name",
    "version",
    "displayName",
    "description",
    "author",
    "main"
  ],
  "additionalProperties": false
}
